# =============================================================================
# Privy-Jiner Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# AI Provider Configuration (choose one or more)
# =============================================================================

# OpenAI (GPT-4, GPT-3.5 Turbo, etc.)
OPENAI_API_KEY=your-openai-api-key-here
# Get your API key from: https://platform.openai.com/api-keys

# Anthropic (Claude 3, Claude 2, etc.)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Get your API key from: https://console.anthropic.com/

# Zhipu AI (GLM models - Chinese)
ZHIPU_API_KEY=your-zhipu-api-key-here
# Get your API key from: https://open.bigmodel.cn/

# =============================================================================
# Server Configuration
# =============================================================================

# Jiner API server port (default: 3001, customize as needed)
JINER_PORT=3001

# OpenClaw URL (default: http://localhost:18789)
OPENCLAW_URL=http://localhost:18789

# =============================================================================
# OpenClaw Plugin Configuration (optional)
# =============================================================================

# Secret for plugin authentication (optional)
OPENCLOW_PLUGIN_SECRET=your-plugin-secret-here

# =============================================================================
# Database Configuration (optional - SQLite is default)
# =============================================================================

# Database type: sqlite, mysql, postgresql
# DATABASE_TYPE=sqlite

# For MySQL/PostgreSQL (if not using SQLite):
# DATABASE_HOST=localhost
# DATABASE_PORT=3306
# DATABASE_USER=root
# DATABASE_PASSWORD=your-db-password
# DATABASE_NAME=privy_jiner

# =============================================================================
# Internationalization
# =============================================================================

# Default language: en, zh
# LANG=zh
